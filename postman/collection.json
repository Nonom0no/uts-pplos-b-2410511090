{
  "info": {
    "name": "UTS PPLOS B — Sistem Tiket Event (NIM 2410511090)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",      "value": "http://localhost:8000" },
    { "key": "access_token",  "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "event_id",      "value": "" },
    { "key": "order_id",      "value": "" },
    { "key": "ticket_id",     "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Uraraka Ochaco\",\n  \"email\": \"uraraka@bnha.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) {",
                  "  pm.collectionVariables.set('access_token',  res.data.access_token);",
                  "  pm.collectionVariables.set('refresh_token', res.data.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"budi@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get Profile (me)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) {",
                  "  pm.collectionVariables.set('access_token',  res.data.access_token);",
                  "  pm.collectionVariables.set('refresh_token', res.data.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/logout",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "OAuth Google — Redirect",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/auth/oauth/google"
          }
        }
      ]
    },
    {
      "name": "2. Events",
      "item": [
        {
          "name": "List Events (public)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/events?status=published&page=1&per_page=10",
              "query": [
                { "key": "status",   "value": "published" },
                { "key": "page",     "value": "1" },
                { "key": "per_page", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Create Event (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) pm.collectionVariables.set('event_id', res.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/events",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Konser Indie Jakarta 2026\",\n  \"description\": \"Konser musik indie terbesar\",\n  \"location\": \"GBK Arena, Jakarta\",\n  \"event_date\": \"2026-07-15 19:00:00\",\n  \"status\": \"published\",\n  \"categories\": [\n    { \"name\": \"Regular\", \"price\": 150000, \"quota\": 500 },\n    { \"name\": \"VIP\",     \"price\": 350000, \"quota\": 100 }\n  ]\n}"
            }
          }
        },
        {
          "name": "Get Event Detail",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/events/{{event_id}}"
          }
        },
        {
          "name": "Update Event",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/events/{{event_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"published\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "3. Orders (Payment)",
      "item": [
        {
          "name": "Checkout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) pm.collectionVariables.set('order_id', res.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/orders",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_id\": \"{{event_id}}\",\n  \"items\": [\n    { \"ticket_category_id\": \"GANTI_DENGAN_ID_KATEGORI\", \"quantity\": 2 }\n  ]\n}"
            }
          }
        },
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/orders?page=1&per_page=10",
              "query": [
                { "key": "page",     "value": "1" },
                { "key": "per_page", "value": "10" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Get Order Detail",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/orders/{{order_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Confirm Payment",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/orders/{{order_id}}/confirm",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payment_method\": \"transfer\"\n}"
            }
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/orders/{{order_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        }
      ]
    },
    {
      "name": "4. Tickets",
      "item": [
        {
          "name": "List My Tickets",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/tickets?page=1&per_page=10",
              "query": [
                { "key": "page",     "value": "1" },
                { "key": "per_page", "value": "10" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Get Ticket Detail",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/tickets/{{ticket_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Validate QR Code",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/tickets/validate-qr",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"qr_code\": \"GANTI_DENGAN_QR_CODE_DARI_TIKET\",\n  \"gate\": \"Gate A\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "5. Health Checks",
      "item": [
        {
          "name": "Gateway Health",
          "request": { "method": "GET", "url": "{{base_url}}/health" }
        },
        {
          "name": "Auth Service Health (direct)",
          "request": { "method": "GET", "url": "http://localhost:3001/health" }
        },
        {
          "name": "Event Service Health (direct)",
          "request": { "method": "GET", "url": "http://localhost:3002/api/health" }
        },
        {
          "name": "Payment Service Health (direct)",
          "request": { "method": "GET", "url": "http://localhost:3003/health" }
        }
      ]
    }
  ]
}